{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2017", "DOM"],
    "typeRoots": ["node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": ".",
    "outDir": "lib",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["./src", "./config", "./types"],
  "compileOnSave": false
}
