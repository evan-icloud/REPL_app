    "@babel/preset-typescript": "^7.23.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/rn-runner": "4.2.0",
    "@tarojs/rn-style-transformer": "4.2.0",
    "@tarojs/rn-supporter": "4.2.0",
    "@tarojs/rn-transformer": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/react": "^18.0.0",
