{
  "name": "invest-app-taro",
  "version": "1.0.0",
  "private": true,
  "description": "智投金融投资交易App - Taro 4.x 跨端",
  "template": "default",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "build:android": "taro build --type rn --platform android",
    "build:ios": "taro build --type rn --platform ios"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not ie 11",
    "not op_mini all",
    "Android >= 7",
    "iOS >= 11"
  ],
  "dependencies": {
    "@babel/runtime": "^7.21.0",
    "@nutui/icons-react-taro": "^1.0.0",
    "@nutui/nutui-react-taro": "^2.6.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native/metro-config": "^0.86.0",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-jd": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tarojs/taro-rn": "4.2.0",
    "dayjs": "^1.11.0",
    "metro": "^0.86.0",
    "metro-core": "^0.86.0",
    "metro-resolver": "^0.86.0",
    "metro-runtime": "^0.86.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-native": "^0.74.0",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "^2.16.2",
    "react-native-reanimated": "^3.10.1",
    "react-native-root-siblings": "^5.0.1",
